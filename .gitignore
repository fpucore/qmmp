# ==============================================================================
# Qmmp Repository (H-Linux) - Git Ignore Rules
# ==============================================================================

# ------------------------------------------------------------------------------
# Arch Linux Packaging Artifacts
# ------------------------------------------------------------------------------
# Ignore the fake root staging directory
pkg/

# Ignore all compiled package binaries (e.g., .pkg.tar.zst)
*.pkg.tar.*
*.src.tar.*

# Ignore downloaded upstream source archives
*.tar.bz2
*.tar.gz
*.tar.xz
*.zip

# ------------------------------------------------------------------------------
# CMake & Compilation Artifacts 
# ------------------------------------------------------------------------------
# Ignore CMake cache and generation directories
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
cmake_uninstall.cmake
install_manifest.txt

# Ignore Makefiles generated by CMake
Makefile
compiler_depend.ts
compiler_depend.make

# Ignore compiled object files, shared libraries, and static libraries
*.o
*.so
*.so.*
*.a

# Ignore the final binary output directory
bin/

# ------------------------------------------------------------------------------
# OS & Editor Metadata
# ------------------------------------------------------------------------------
# Ignore script execution logs
*.log

# Ignore common editor swap and backup files
*~
*.swp
*.bk
*.bak
*.orig
.vscode/
